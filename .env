# =============================================================================
# GraphRAG Inference Hackathon - Environment Variables
# =============================================================================

# Groq API Keys (rotates when daily limit hit)
GROQ_API_KEY=REMOVED_FOR_GITHUB
GROQ_API_KEY_2=REMOVED_FOR_GITHUB

# TigerGraph Local Docker (Community Edition)
TG_HOST=http://localhost
TG_USERNAME=tigergraph
TG_PASSWORD=tigergraph
TG_SECRET=
TG_GRAPHNAME=GraphRAGHackathon
TG_RESTPP_PORT=14240
TG_GS_PORT=14240

# GraphRAG Service URL (local Docker)
GRAPHRAG_HOST=http://localhost:8000

# HuggingFace Token (optional, for BERTScore model download)
HF_TOKEN=REMOVED_FOR_GITHUB
