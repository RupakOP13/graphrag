# =============================================================================
# GraphRAG Inference Hackathon - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys

# Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# TigerGraph Savanna Credentials (get from https://tgcloud.io)
TG_HOST=https://your-instance.i.tgcloud.io
TG_USERNAME=tigergraph
TG_PASSWORD=your_password_here
TG_GRAPHNAME=GraphRAGHackathon
TG_RESTPP_PORT=443
TG_GS_PORT=443

# GraphRAG Service URL (Docker-based)
GRAPHRAG_HOST=http://localhost:8000

# HuggingFace Token (for LLM-as-a-Judge, optional if using free inference)
HF_TOKEN=your_huggingface_token_here
